{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "rootDir": "src",
    "outDir": "lib",
    "types": [],
    "typeRoots": ["./node_modules/@types"],
    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "sourceMap": true
  },
  "include": [
    "src"
  ]
}

